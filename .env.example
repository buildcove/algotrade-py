# Copy to `.env` for local development.
#
# TradingView (cookie-based token extraction)
tradingview_sessionid=

# IBKR
ib_account=

# API basic auth (optional). When both are set, scheduler endpoints require auth.
# If left blank, API auth is disabled (useful for local-only runs).
basic_username=
basic_password=

# App
user_tz=Asia/Manila
is_live=false
live_confirm=
